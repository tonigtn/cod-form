{% comment %}
  COD Order Form — App Embed block (appears in App embeds panel).
  Renders globally. On product pages, fetches product data via AJAX
  and bootstraps the form. Skips if the per-template block is present.
{% endcomment %}

{{ 'cod-form.css' | asset_url | stylesheet_tag }}

{% if request.page_type == 'product' %}
<div id="cod-embed-root" style="display:none">
  <div class="cod-form-overlay" id="cod-form-overlay" role="dialog" aria-modal="true" hidden>
    <div class="cod-form" id="cod-form-panel">
      <div class="cod-form__announcement" id="cod-announcement" hidden></div>
      <button type="button" class="cod-form__close" id="cod-form-close" aria-label="Close">&times;</button>

      <form id="cod-order-form" novalidate>
        <div class="cod-form__fields">
        <div class="cod-form__field" data-field-id="first_name">
          <label for="cod-first-name">{{ 'sections.cod_form.first_name' | t }} <span class="cod-required">*</span></label>
          <input type="text" id="cod-first-name" name="first_name" required autocomplete="given-name">
          <span class="cod-form__error" data-error="first_name"></span>
        </div>

        <div class="cod-form__field" data-field-id="last_name">
          <label for="cod-last-name">{{ 'sections.cod_form.last_name' | t }} <span class="cod-required">*</span></label>
          <input type="text" id="cod-last-name" name="last_name" required autocomplete="family-name">
          <span class="cod-form__error" data-error="last_name"></span>
        </div>

        <div class="cod-form__field" data-field-id="phone">
          <label for="cod-phone">{{ 'sections.cod_form.phone' | t }} <span class="cod-required">*</span></label>
          <input type="tel" id="cod-phone" name="phone" required autocomplete="tel">
          <span class="cod-form__error" data-error="phone"></span>
        </div>

        <div class="cod-form__field" data-field-id="province">
          <label for="cod-province">{{ 'sections.cod_form.province' | t }} <span class="cod-required">*</span></label>
          <select id="cod-province" name="province" required>
            <option value="">{{ 'sections.cod_form.select_province' | t }}</option>
          </select>
          <span class="cod-form__error" data-error="province"></span>
        </div>

        <div class="cod-form__field" data-field-id="city">
          <label for="cod-city">{{ 'sections.cod_form.city' | t }} <span class="cod-required">*</span></label>
          <input type="text" id="cod-city" name="city" required autocomplete="address-level2">
          <span class="cod-form__error" data-error="city"></span>
        </div>

        <div class="cod-form__field" data-field-id="address1">
          <label for="cod-address">{{ 'sections.cod_form.address' | t }} <span class="cod-required">*</span></label>
          <input type="text" id="cod-address" name="address1" required autocomplete="street-address" placeholder="{{ 'sections.cod_form.address_placeholder' | t }}">
          <span class="cod-form__error" data-error="address1"></span>
        </div>

        <div class="cod-form__field" data-field-id="zip">
          <label for="cod-zip">{{ 'sections.cod_form.zip' | t }}</label>
          <input type="text" id="cod-zip" name="zip" autocomplete="postal-code">
          <span class="cod-form__error" data-error="zip"></span>
        </div>

        <div class="cod-form__field" data-field-id="email">
          <label for="cod-email">{{ 'sections.cod_form.email' | t }}</label>
          <input type="email" id="cod-email" name="email" autocomplete="email">
          <span class="cod-form__error" data-error="email"></span>
        </div>

        </div><!-- /.cod-form__fields -->

        <div class="cod-form__summary">
          <div class="cod-form-offers" id="cod-form-offers" hidden></div>
          <div class="cod-form__header" id="cod-form-header">
            <img class="cod-form__product-img" id="cod-product-img" src="" alt="" width="80" height="80">
            <div class="cod-form__product-info">
              <div class="cod-form__product-title" id="cod-product-title"></div>
              <div class="cod-form__price-wrap">
                <span class="cod-form__product-price" id="cod-price"></span>
                <span class="cod-form__compare-price" id="cod-compare-price"></span>
              </div>
            </div>
          </div>

          <div class="cod-form__discount" id="cod-discount-section" hidden>
            <a class="cod-form__discount-toggle" id="cod-discount-toggle" href="#">{{ 'sections.cod_form.discount_toggle' | t }}</a>
            <div class="cod-form__discount-row" id="cod-discount-row" hidden>
              <input type="text" id="cod-discount-code" placeholder="{{ 'sections.cod_form.discount_placeholder' | t }}" style="text-transform:uppercase">
              <button type="button" id="cod-discount-apply">{{ 'sections.cod_form.discount_apply' | t }}</button>
            </div>
            <div id="cod-discount-result"></div>
          </div>

          <div class="cod-form__line"><span>{{ 'sections.cod_form.subtotal' | t }}</span><span id="cod-subtotal"></span></div>
          <div class="cod-form__line cod-form__line--discount"><span id="cod-discount-label" style="color:var(--color-primary,#b5a1e0)">{{ 'sections.cod_form.discount' | t }}</span><span id="cod-discount-amount"></span></div>
          <div class="cod-form__line"><span>{{ 'sections.cod_form.shipping' | t }}</span><span id="cod-shipping"></span></div>
          <div class="cod-form__line" id="cod-fee-line"><span id="cod-fee-label"></span><span id="cod-fee-amount"></span></div>
          <div class="cod-form__line" id="cod-added-products-line" style="color:var(--color-primary,#b5a1e0)"><span id="cod-added-label"></span><span id="cod-added-amount"></span></div>
          <div class="cod-form__line cod-form__line--total"><span><b>{{ 'sections.cod_form.total' | t }}</b></span><span id="cod-total"><b></b></span></div>
        </div>

        <div class="cod-form__bumps" id="cod-bumps" hidden></div>

        <button type="button" class="cod-form__submit" id="cod-submit-btn"
          onclick="document.getElementById('cod-order-form').dispatchEvent(new Event('submit',{cancelable:true,bubbles:true}))"
          style="display:flex;flex-direction:column;align-items:center;justify-content:center;width:100%;min-height:52px;padding:14px 24px;font-size:16px;font-weight:600;color:#fff;background:var(--color-primary,#b5a1e0);border:none;border-radius:8px;cursor:pointer;margin-top:16px;">
          <span class="cod-form__submit-text" style="display:flex;flex-direction:column;align-items:center;">
            <span>{{ 'sections.cod_form.submit' | t }}</span>
            <span style="font-size:0.9rem;text-transform:uppercase;opacity:0.85;margin-top:2px;">PLATA LA LIVRARE</span>
          </span>
          <span class="cod-form__submit-loading" hidden>
            <svg width="20" height="20" viewBox="0 0 24 24" class="cod-spinner"><circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="3" stroke-dasharray="31.4" stroke-linecap="round"><animateTransform attributeName="transform" type="rotate" from="0 12 12" to="360 12 12" dur="0.8s" repeatCount="indefinite"/></circle></svg>
          </span>
        </button>

        <div id="cod-prepaid-wrapper" hidden></div>
      </form>

      <div class="cod-form__success" id="cod-success" hidden>
        <div class="cod-form__success-icon">✓</div>
        <h3 id="cod-success-title">{{ 'sections.cod_form.success_title' | t }}</h3>
        <p id="cod-success-text">{{ 'sections.cod_form.success_text' | t }}</p>
        <p id="cod-success-order"></p>
        <div id="cod-upsells"></div>
        <button type="button" class="cod-form__submit" id="cod-success-close"
          style="background:var(--color-primary,#b5a1e0);color:#fff;border:none;padding:14px;border-radius:8px;width:100%;font-size:16px;font-weight:600;cursor:pointer;">
          {{ 'sections.cod_form.close' | t }}
        </button>
      </div>

      <div class="cod-form__error" id="cod-error" hidden>
        <p id="cod-error-msg"></p>
        <button type="button" id="cod-error-retry" class="cod-form__submit"
          style="background:var(--color-primary,#b5a1e0);color:#fff;border:none;padding:14px;border-radius:8px;width:100%;font-size:16px;font-weight:600;cursor:pointer;">
          Retry
        </button>
      </div>
    </div>
  </div>

  <div id="cod-sticky-bar" hidden></div>
</div>

<script>
(function() {
  // Skip if the per-template block already rendered the form
  if (document.getElementById('cod-form-wrapper')) return;

  // Get product handle from URL
  var match = window.location.pathname.match(/\/products\/([^/?#]+)/);
  if (!match) return;

  // Fetch product data via Shopify AJAX API
  fetch('/products/' + match[1] + '.json')
    .then(function(r) { return r.json(); })
    .then(function(data) {
      var product = data.product;
      if (!product || !product.available) return;

      // Find first available variant
      var variant = product.variants[0];
      for (var i = 0; i < product.variants.length; i++) {
        if (product.variants[i].available) { variant = product.variants[i]; break; }
      }

      // Shopify AJAX API returns prices as strings like "59.99"
      var price = parseFloat(variant.price);
      var compareAt = variant.compare_at_price ? parseFloat(variant.compare_at_price) : 0;

      // Populate product info in the overlay
      var root = document.getElementById('cod-embed-root');
      if (!root) return;
      root.style.display = '';

      var img = document.getElementById('cod-product-img');
      if (img && product.image) { img.src = product.image.src; img.alt = product.title; }

      var title = document.getElementById('cod-product-title');
      if (title) title.textContent = product.title;

      var priceEl = document.getElementById('cod-price');
      if (priceEl) priceEl.textContent = price.toFixed(2) + ' {{ cart.currency.iso_code }}';

      var cpEl = document.getElementById('cod-compare-price');
      if (cpEl && compareAt > price) cpEl.textContent = compareAt.toFixed(2) + ' {{ cart.currency.iso_code }}';

      // Build data attributes and load the main JS
      var s = document.createElement('script');
      s.src = '{{ "cod-form.js" | asset_url }}';
      s.defer = true;
      s.setAttribute('data-cod-api-url', 'https://api.magazinultarii.ro');
      s.setAttribute('data-shop', typeof Shopify !== 'undefined' ? Shopify.shop : '{{ shop.permanent_domain }}');
      s.setAttribute('data-product-id', product.id);
      s.setAttribute('data-variant-id', variant.id);
      s.setAttribute('data-unit-price', price.toString());
      if (compareAt > price) s.setAttribute('data-compare-price', compareAt.toString());
      s.setAttribute('data-currency', '{{ cart.currency.iso_code }}');
      s.setAttribute('data-product-title', product.title);
      s.setAttribute('data-product-image', product.image ? product.image.src : '');

      // Multi-variant support
      if (product.variants.length > 1) {
        s.setAttribute('data-variant-option-name', product.options[0]);
        var variants = product.variants.map(function(v) {
          return {
            t: v.title,
            p: parseFloat(v.price).toString(),
            cp: (v.compare_at_price && parseFloat(v.compare_at_price) > parseFloat(v.price))
              ? parseFloat(v.compare_at_price).toString() : '',
            img: v.featured_image ? v.featured_image.src : (product.image ? product.image.src : ''),
            ok: v.available
          };
        });
        s.setAttribute('data-variants', JSON.stringify(variants));
      }

      document.body.appendChild(s);
    })
    .catch(function() {});
})();
</script>
{% endif %}

{% schema %}
{
  "name": "COD Order Form",
  "target": "body",
  "settings": []
}
{% endschema %}
