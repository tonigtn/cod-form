# Database
DATABASE_URL=postgresql://cod_form_user:password@localhost:5432/cod_form

# Shopify App (from Shopify Partners dashboard)
SHOPIFY_CLIENT_ID=your_client_id
SHOPIFY_CLIENT_SECRET=your_client_secret

# App URL (public HTTPS)
APP_BASE_URL=https://your-domain.com

# Encryption key for stored access tokens
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your_fernet_key

# Optional: API key for direct (non-proxy) storefront access
COD_API_KEY=

# Optional: WhatsApp Business API (for OTP + order confirmations)
WHATSAPP_ACCESS_TOKEN=
# Per-shop WhatsApp phone number IDs are stored in shop config

# Optional: Additional app credentials for multi-app setups
# SHOPIFY_CLIENT_ID_2=
# SHOPIFY_CLIENT_SECRET_2=
